    <Compile Remove="lib\SDL2-CS\src\SDL2_ttf.cs" />
    <Compile Remove="lib\SDL2-CS\src\SDL2_mixer.cs" />
    <Compile Remove="lib\SDL2-CS\src\SDL2_image.cs" />
