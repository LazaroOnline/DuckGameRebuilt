    <Compile Remove="abi\Microsoft.Xna.Framework.Net.cs" />
    <Compile Remove="abi\Microsoft.Xna.Framework.Input.Touch.cs" />
    <Compile Remove="abi\Microsoft.Xna.Framework.Graphics.cs" />
    <Compile Remove="abi\Microsoft.Xna.Framework.GamerServices.cs" />
