<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>9.0</LangVersion>
    <OutputType>Library</OutputType>
    <Platforms>x86</Platforms>
    <RootNamespace>DuckGame.Cobalt</RootNamespace>
    <OutputPath>bin</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
    <Configurations>Debug;Release;Release50pHost;ReleaseAutoUpdater</Configurations>
    <AssemblyTitle>Duck Game Rebuilt</AssemblyTitle>
    <AssemblyVersion>1.0.0</AssemblyVersion>
    <Authors>DGR Team</Authors>
    <Description>An installer and manager mod for Duck Game Rebuilt</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\DuckGame\DuckGame.csproj">
      <ExcludeAssets>all</ExcludeAssets>
      <Private>false</Private>
    </ProjectReference>
    <PackageReference Include="BsDiff" Version="1.1.0" />
  </ItemGroup>
  <ItemGroup>
    <ModFiles Include="bin\Rebuilder.dll" />
  </ItemGroup>
  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <Copy SourceFiles="@(ModFiles)" DestinationFolder=".." SkipUnchangedFiles="true" />
  </Target>
</Project>